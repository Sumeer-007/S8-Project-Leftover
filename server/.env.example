# PostgreSQL connection string (production)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leftoverlink

# For local dev without PostgreSQL, use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./leftoverlink.db

# JWT secret - use a strong random value in production
SECRET_KEY=your-secret-key-change-in-production

# CORS allowed origins for the main PWA (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Admin app is built and deployed separately. Set its full URL(s) so it can fetch donations (comma-separated).
# Leave empty for local dev (localhost:5174 is allowed by default). Example for production:
# ADMIN_CORS_ORIGINS=https://admin.yourdomain.com
# ADMIN_CORS_ORIGINS=

# Google Maps API key - required for Geocoding & Places endpoints
# Enable: Geocoding API, Places API (Places API, Places Autocomplete)
# https://console.cloud.google.com/apis/library
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Resend.com API key - for sending delivery + feedback link emails to end users (free: 100/day)
# https://resend.com - leave empty to skip sending (log only)
# RESEND_API_KEY=re_xxxx

# Verified sender for Resend (recommended for production; after domain verification)
# Example: EMAIL_FROM=Leftover Link <noreply@yourdomain.com>
# EMAIL_FROM=

# Debug email delivery on POST /tasks/{id}/deliver:
# - true: send synchronously and include emailAttempted/emailSent/emailError in response
# - false: send in background (default)
# DELIVERY_EMAIL_DEBUG=false

# Base URL of the client app - used for feedback links in emails
CLIENT_BASE_URL=http://localhost:5173

# Optional external feedback URL (if set, email links go here instead of CLIENT_BASE_URL/feedback/{token})
# Example: FEEDBACK_PUBLIC_URL=https://forms.gle/your-form-id
# FEEDBACK_PUBLIC_URL=

# Optional: HTTPS open-URL for web push when CLIENT_BASE_URL is http://localhost (FCM requires HTTPS for that field)
# Example Firebase Hosting: https://leftover-link-13fa4.web.app
# FCM_WEB_PUSH_LINK=

# Debug mode (SQL echo, etc.). Also enables GET /debug/fcm without a secret.
DEBUG=false

# Optional: GET /debug/fcm?key=<this> and POST /debug/fcm/test-send?key=<this> for FCM diagnostics
# (use when DEBUG=false). Generate a long random string.
# FCM_DEBUG_SECRET=

# Firebase Admin credentials (Firebase Console → Project settings → Service accounts).
# Preferred: set full service account values in env (works without JSON file in git).
# Keep \n escape sequences in FIREBASE_PRIVATE_KEY as shown below.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY_ID=your-private-key-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINES\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_CLIENT_ID=12345678901234567890
# FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxx%40your-project.iam.gserviceaccount.com
# Optional (defaults are usually correct):
# FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
# FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
# FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
# FIREBASE_UNIVERSE_DOMAIN=googleapis.com
#
# Fallback: file-based credentials path (still supported).
# FIREBASE_CREDENTIALS_PATH=C:/Users/You/.../Leftover/server/leftover-link-xxx-firebase-adminsdk.json
